modules = ["nodejs-22"]

run = "npm run dev"
entrypoint = "index.html"
hidden = [".config", "package-lock.json"]

[nix]
channel = "stable-24_05"

[env]
VITE_HOST = "0.0.0.0"

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 4173
externalPort = 3000

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"

[workflows]
runButton = "Dev"

[[workflows.workflow]]
name = "Dev"
author = "aurzo"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run dev -- --host 0.0.0.0 --port 5173"

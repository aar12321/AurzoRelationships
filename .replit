modules = ["nodejs-22"]

run = "npm run dev"
entrypoint = "index.html"
hidden = [".config", "package-lock.json"]

[nix]
channel = "stable-24_05"

[env]
VITE_HOST = "0.0.0.0"

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 4173
externalPort = 3000

# Autoscale deployment — Replit spins up vite preview to serve `dist/`.
# For a pure SPA you could also pick "static" in the UI (cheaper, no server);
# this config supports both. Replit injects $PORT at runtime.
[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[workflows]
runButton = "Dev"

[[workflows.workflow]]
name = "Dev"
author = "aurzo"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run dev -- --host 0.0.0.0 --port 5173"

[agent]
expertMode = true

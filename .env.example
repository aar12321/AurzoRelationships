# Shared Aurzo Supabase project — every Aurzo app uses the same URL + key.
# The client accepts either the Vite-style or the Next-style names so the
# same .env works across Vite (web), Next.js apps, and React Native bundlers.

VITE_SUPABASE_URL=https://lnvebvrayuveygycpolc.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_ifskZ-illR5oea_tvMlgLQ_jCVIXmIR

NEXT_PUBLIC_SUPABASE_URL=https://lnvebvrayuveygycpolc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ifskZ-illR5oea_tvMlgLQ_jCVIXmIR

# Which Aurzo platform this build represents. Scopes every write to the
# universal aurzo_core.* tables (ai_cache, search_history, user_selections).
VITE_PLATFORM_ID=relationship_os

# Aurzo SSO redirect (optional — Supabase handles the auth flow directly).
VITE_AURZO_SSO_URL=

# Server-side only — never ship to the client bundle. Claude API calls for
# the advisor, composer, gift ideas, date ideas, and weekly pulse should
# proxy through a backend function that reads this.
ANTHROPIC_API_KEY=

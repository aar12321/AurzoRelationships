{
  "name": "aurzo-relationship-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Aurzo Relationship OS — a private, thoughtful tool for maintaining and deepening the relationships that matter most.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/spa-fallback.mjs",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0 --port 4173",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.19",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^4.1.5"
  }
}
